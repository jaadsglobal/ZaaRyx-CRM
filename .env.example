# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Supabase PostgreSQL Database
SUPABASE_URL="https://tebivwyzhqlrabpoonru.supabase.co"
SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# Supabase Auth for browser login. The frontend only receives VITE_* variables.
VITE_SUPABASE_URL="https://tebivwyzhqlrabpoonru.supabase.co"
VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY="your-supabase-publishable-key"

# SMTP configuration for transactional emails such as password recovery.
# Works with Gmail app passwords or any standard SMTP provider.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your-account@gmail.com"
SMTP_PASS="your-app-password"
MAIL_FROM="ZaaRyx CRM <your-account@gmail.com>"

# Production security hardening.
# TRUST_PROXY: enable only if the app runs behind a reverse proxy that forwards the client IP
# and HTTPS scheme correctly (for example Nginx, Traefik, Cloudflare or a platform LB).
TRUST_PROXY="false"

# SECURE_COOKIES: force session cookies to use the Secure flag.
# Normally not needed if TRUST_PROXY is enabled and the public request is HTTPS.
SECURE_COOKIES="false"

# Maximum accepted size for JSON API bodies.
JSON_BODY_LIMIT="1mb"

# STRICT_PRODUCTION_CHECKS: abort startup in production if readiness detects critical issues.
STRICT_PRODUCTION_CHECKS="false"

# Optional release identifier exposed by /healthz and /readyz.
RELEASE_VERSION="2026.03.11"
